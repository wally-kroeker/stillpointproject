---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const stories = await getCollection('stories');
// Sort by word count or title
const sortedStories = stories.sort((a, b) => {
  const aWordCount = a.data.word_count || 0;
  const bWordCount = b.data.word_count || 0;
  return bWordCount - aWordCount; // Largest first
});

const storiesListSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": "Short Stories from The StillPoint Universe",
	"url": "https://stillpointproject.org/stories",
	"description": "Standalone stories exploring different perspectives and moments across the StillPoint saga — from AI-driven crisis to contemplative renaissance.",
	"hasPart": sortedStories.map((story) => ({
		"@type": "ShortStory",
		"name": story.data.title,
		"url": `https://stillpointproject.org/stories/${story.id}`,
		"description": story.data.description || undefined,
		"wordCount": story.data.word_count || undefined
	}))
};
---

<Layout title="Short Stories - The StillPoint" description="Short stories from The StillPoint universe. Explore AI consciousness, intentional communities, and contemplative technology across standalone tales. Free to read.">
	<script type="application/ld+json" set:html={JSON.stringify(storiesListSchema)} />
	<section class="hero">
		<div class="hero-overlay">
			<div class="hero-content">
				<h1>Short Stories</h1>
				<p class="subtitle">Standalone stories from The StillPoint world, exploring different perspectives and moments across the journey from acceleration to presence.</p>
			</div>
		</div>
	</section>

	<main>
		<div class="container">
			<div class="stories-grid">
				{sortedStories.map((story) => (
					<article class="story-card">
						<div class="story-card-body">
							<h3>
								<a href={`/stories/${story.id}`} class="card-link">
									{story.data.title}
								</a>
							</h3>
							{story.data.description && (
								<p class="story-description">{story.data.description}</p>
							)}
						</div>
						<div class="story-meta">
							<span class="word-count">
								{story.data.word_count
									? `${Math.ceil(story.data.word_count / 250)} min read`
									: 'Short Story'}
							</span>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</Layout>

<style>
	@import '../styles/design-tokens.css';

	/* Hero Section */
	.hero {
		position: relative;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		height: 40vh;
		min-height: 300px;
		max-height: 450px;
		background-image: url('/images/riverbend_hero.webp');
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
		margin-bottom: var(--space-2xl);
		border-bottom: 1px solid var(--color-accent-1);
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(
			180deg,
			rgba(15, 26, 30, 0.4) 0%,
			rgba(15, 26, 30, 0.8) 70%,
			var(--color-bg) 100%
		);
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding: var(--space-lg);
	}

	.hero-content {
		text-align: center;
		max-width: 800px;
		color: var(--color-text);
		z-index: 10;
		padding-bottom: var(--space-2xl);
	}

	.hero h1 {
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		font-weight: 300;
		margin-bottom: var(--space-md);
		color: var(--color-heading);
		text-shadow: 0 4px 12px rgba(0, 0, 0, 0.8);
		font-family: var(--font-serif);
		letter-spacing: -0.02em;
	}

	.subtitle {
		font-size: clamp(1.1rem, 1.5vw, 1.3rem);
		line-height: var(--line-height-relaxed);
		color: var(--color-text);
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
		max-width: 600px;
		margin: 0 auto;
		font-weight: 300;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 var(--space-lg) var(--space-3xl);
	}

	.stories-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: var(--space-lg);
	}

	.story-card {
		border: 1px solid var(--color-border);
		border-left: 4px solid var(--color-accent-1);
		border-radius: 12px;
		padding: var(--space-lg);
		background: var(--color-bg-glass);
		transition: all var(--transition-normal);
		position: relative;
		backdrop-filter: blur(10px);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.story-card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-4px);
		border-left-color: var(--color-accent-2);
		border-color: var(--color-accent-2);
	}

	.story-card h3 {
		margin: 0 0 var(--space-md) 0;
		color: var(--color-heading);
		font-size: var(--font-size-xl);
		line-height: 1.3;
		font-family: var(--font-serif);
	}

	.story-card-body {
		flex: 1;
	}

	.story-description {
		color: var(--color-text-muted);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		margin-top: var(--space-sm);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-link {
		text-decoration: none;
		color: inherit;
		transition: color var(--transition-fast);
	}

	.card-link::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.story-card:hover .card-link {
		color: var(--color-accent-1);
	}

	.story-meta {
		display: flex;
		justify-content: flex-end;
		margin-top: var(--space-md);
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-sm);
	}

	.word-count {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	@media (max-width: 1024px) {
		.hero {
			height: 30vh;
			min-height: 250px;
			background-attachment: scroll;
		}
		
		.container {
			padding: 0 var(--space-md) var(--space-2xl);
		}
	}
</style>