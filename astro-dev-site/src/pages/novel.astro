---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const novelScenes = await getCollection('novel', ({ data }) => {
	// Only show published content - exclude draft and revision status
	return data.status !== 'draft' && data.status !== 'revision';
});
// Sort by filename to maintain chapter order
const sortedScenes = novelScenes.sort((a, b) => a.id.localeCompare(b.id));

// Parse chapter/scene from ID (e.g., "e1_c01_s01_the_daydream" → { chapter: "E1C01", scene: "S01" })
function parseChapterScene(id: string): { chapter: string; scene: string } | null {
	const match = id.match(/e(\d+)_c(\d+)_s(\d+)/);
	if (!match) return null;
	return { chapter: `E${match[1]}C${match[2]}`, scene: `S${match[3]}` };
}

// Format chapter/scene for display (e.g., "E1C01" + "S01" → "Ch. 01.01")
function formatChapterLabel(chapter: string, scene: string): string {
	const ch = chapter.replace(/E\d+C/, 'Ch. ');
	const sc = scene.replace('S', '.');
	return `${ch}${sc}`;
}

const bookStructuredData = {
	"@context": "https://schema.org",
	"@type": "Book",
	"name": "The StillPoint Saga",
	"alternateName": "The StillPoint",
	"author": { "@type": "Person", "name": "Wally Kroeker" },
	"url": "https://stillpointproject.org/novel",
	"genre": ["Science Fiction", "Contemplative Fiction", "Speculative Fiction"],
	"inLanguage": "en",
	"bookFormat": "https://schema.org/EBook",
	"description": "A multi-era science fiction novel spanning 2029-2095, exploring what happens when AI reshapes society and humanity discovers presence as the antidote to acceleration.",
	"hasPart": sortedScenes.map((scene, index) => ({
		"@type": "Chapter",
		"name": scene.data.title,
		"url": `https://stillpointproject.org/novel/${scene.id}`,
		"position": index + 1
	}))
};
---

<Layout title="The StillPoint - Novel Chapters" description="Read The StillPoint Saga free online. Published chapters following humanity from AI-driven crisis to contemplative renaissance. Start with The Cascade.">
	<script type="application/ld+json" set:html={JSON.stringify(bookStructuredData)} />
	<section class="hero">
		<div class="hero-overlay">
			<div class="hero-content">
				<h1>The StillPoint</h1>
				<p class="subtitle">Start the journey. Published chapters from The Cascade, updated as the story unfolds.</p>
			</div>
		</div>
	</section>

	<main>
		<div class="container">
			<div class="era-section">
				<h2>The Cascade</h2>
				<p class="era-description">The acceleration breaks us. Jobs vanish, meaning dissolves. In the chaos, one invention offers an answer.</p>

				<div class="chapters">
					{sortedScenes.map((scene) => {
						const parsed = parseChapterScene(scene.id);
						const chapter = scene.data.chapter || parsed?.chapter;
						const sceneNum = scene.data.scene || parsed?.scene;
						const label = chapter && sceneNum ? formatChapterLabel(chapter, sceneNum) : null;
						return (
						<article class="scene-card">
							<div class="scene-info">
								{label && <span class="chapter-number">{label}</span>}
								<h3>
									<a href={`/novel/${scene.id}`} class="card-link">
										{scene.data.title}
									</a>
								</h3>
							</div>
							<div class="scene-meta">
								{scene.data.word_count && (
									<span class="reading-time">{Math.ceil(scene.data.word_count / 250)} min read</span>
								)}
								<span class="read-link">Read Chapter →</span>
							</div>
						</article>
					);})}
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	@import '../styles/design-tokens.css';

	/* Hero Section */
	.hero {
		position: relative;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		height: 60vh;
		min-height: 400px;
		max-height: 600px;
		background-image: url('/images/hawthorne_hero.webp');
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
		margin-bottom: var(--space-2xl);
		border-bottom: 1px solid var(--color-accent-1);
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(
			180deg,
			rgba(15, 26, 30, 0.4) 0%,
			rgba(15, 26, 30, 0.8) 70%,
			var(--color-bg) 100%
		);
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding: var(--space-lg);
	}

	.hero-content {
		text-align: center;
		max-width: 800px;
		color: var(--color-text);
		z-index: 10;
		padding-bottom: var(--space-3xl);
	}

	.hero h1 {
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		font-weight: 300;
		margin-bottom: var(--space-md);
		color: var(--color-heading);
		text-shadow: 0 4px 12px rgba(0, 0, 0, 0.8);
		font-family: var(--font-serif);
		letter-spacing: -0.02em;
	}

	.subtitle {
		font-size: clamp(1.1rem, 1.5vw, 1.3rem);
		line-height: var(--line-height-relaxed);
		color: var(--color-text);
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
		max-width: 600px;
		margin: 0 auto;
		font-weight: 300;
	}

	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--space-lg) var(--space-3xl);
	}

	.era-section {
		margin-bottom: var(--space-3xl);
	}

	.era-section h2 {
		color: var(--color-heading);
		border-bottom: 1px solid var(--color-accent-1);
		padding-bottom: var(--space-sm);
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		margin-bottom: var(--space-xs);
	}

	.era-description {
		color: var(--color-text-muted);
		margin-bottom: var(--space-xl);
		font-size: var(--font-size-lg);
	}

	.chapters {
		display: grid;
		gap: var(--space-md);
	}

	.scene-card {
		border: 1px solid var(--color-border);
		border-left: 4px solid var(--color-accent-1);
		border-radius: 8px;
		padding: var(--space-lg);
		background: var(--color-bg-glass);
		transition: all var(--transition-normal);
		backdrop-filter: blur(10px);
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
	}

	.scene-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		border-left-color: var(--color-accent-2);
		border-color: var(--color-accent-2);
	}

	.scene-info {
		flex: 1;
		min-width: 0;
	}

	.chapter-number {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent-1);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		display: block;
		margin-bottom: var(--space-xs);
	}

	.scene-card h3 {
		margin: 0;
		color: var(--color-heading);
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
	}

	.card-link {
		text-decoration: none;
		color: inherit;
		transition: color var(--transition-fast);
	}

	.card-link::after {
		content: '';
		display: block;
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 1;
	}

	.scene-card:hover .card-link {
		color: var(--color-accent-1);
	}

	.scene-meta {
		margin-left: var(--space-md);
		display: flex;
		align-items: center;
		gap: var(--space-md);
		white-space: nowrap;
		position: relative;
		z-index: 2;
	}

	.reading-time {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.read-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-accent-1);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.7;
		transition: opacity var(--transition-fast);
	}

	.scene-card:hover .read-link {
		opacity: 1;
	}

	@media (max-width: 1024px) {
		.hero {
			height: 30vh;
			min-height: 250px;
			background-attachment: scroll;
		}

		.container {
			padding: 0 var(--space-md) var(--space-2xl);
		}

		.scene-card {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-sm);
		}

		.scene-meta {
			margin-left: 0;
		}
	}
</style>