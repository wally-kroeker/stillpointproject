---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PretextDemo from '../../components/PretextDemo';

// Get ALL novel scenes regardless of status
const novelScenes = await getCollection('novel');
const sortedScenes = novelScenes.sort((a, b) => a.id.localeCompare(b.id));

// Also get stories
const stories = await getCollection('stories');
const sortedStories = stories.sort((a, b) => a.id.localeCompare(b.id));

function parseChapterScene(id: string): { chapter: string; scene: string } | null {
	const match = id.match(/e(\d+)_c(\d+)_s(\d+)/);
	if (!match) return null;
	return { chapter: `E${match[1]}C${match[2]}`, scene: `S${match[3]}` };
}

function formatChapterLabel(chapter: string, scene: string): string {
	const ch = chapter.replace(/E\d+C/, 'Ch. ');
	const sc = scene.replace('S', '.');
	return `${ch}${sc}`;
}

function statusBadge(status: string): string {
	const colors: Record<string, string> = {
		'draft': '#f59e0b',
		'draft-revised': '#f97316',
		'revision': '#a855f7',
		'revised': '#8b5cf6',
		'proofread': '#3b82f6',
		'published': '#10b981',
		'canonical': '#06d6a0',
	};
	return colors[status] || '#6b7280';
}
---

<Layout title="Drafts — Nothing to See Here" description="Private drafts workspace.">
	<section class="hero">
		<div class="hero-overlay">
			<div class="hero-content">
				<h1>Nothing to See Here</h1>
				<p class="subtitle">Private drafts. Work in progress. If you found this page, good for you — pull up a chair.</p>
			</div>
		</div>
	</section>

	<main>
		<div class="container">
			<div class="era-section">
				<h2>Typography Lab</h2>
				<p class="era-description">Experimenting with Pretext — DOM-free text layout with Knuth-Plass justification.</p>
				<PretextDemo client:load />
			</div>

			<div class="era-section">
				<h2>Novel Chapters</h2>
				<p class="era-description">All chapters, all statuses. Drafts, revisions, published — everything.</p>

				<div class="chapters">
					{sortedScenes.map((scene) => {
						const parsed = parseChapterScene(scene.id);
						const chapter = scene.data.chapter || parsed?.chapter;
						const sceneNum = scene.data.scene || parsed?.scene;
						const label = chapter && sceneNum ? formatChapterLabel(chapter, sceneNum) : null;
						return (
						<article class="scene-card">
							<div class="scene-info">
								<div class="card-top">
									{label && <span class="chapter-number">{label}</span>}
									<span class="status-badge" style={`--badge-color: ${statusBadge(scene.data.status)}`}>
										{scene.data.status}
									</span>
								</div>
								<h3>
									<a href={`/nothingtoseehere/${scene.id}`} class="card-link">
										{scene.data.title}
									</a>
								</h3>
							</div>
							<div class="scene-meta">
								{scene.data.word_count && (
									<span class="word-count">{scene.data.word_count.toLocaleString()} words</span>
								)}
								{scene.data.word_count && (
									<span class="reading-time">{Math.ceil(scene.data.word_count / 250)} min</span>
								)}
								<span class="read-link">Read →</span>
							</div>
						</article>
					);})}
				</div>
			</div>

			{sortedStories.length > 0 && (
				<div class="era-section">
					<h2>Short Stories</h2>
					<p class="era-description">All stories, all statuses.</p>

					<div class="chapters">
						{sortedStories.map((story) => (
							<article class="scene-card">
								<div class="scene-info">
									<div class="card-top">
										<span class="chapter-number">{story.data.type || 'story'}</span>
										<span class="status-badge" style={`--badge-color: ${statusBadge(story.data.status)}`}>
											{story.data.status}
										</span>
									</div>
									<h3>
										<a href={`/nothingtoseehere/story/${story.id}`} class="card-link">
											{story.data.title}
										</a>
									</h3>
								</div>
								<div class="scene-meta">
									{story.data.word_count && (
										<span class="word-count">{story.data.word_count.toLocaleString()} words</span>
									)}
									<span class="read-link">Read →</span>
								</div>
							</article>
						))}
					</div>
				</div>
			)}
		</div>
	</main>
</Layout>

<style>
	@import '../../styles/design-tokens.css';

	.hero {
		position: relative;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		height: 30vh;
		min-height: 200px;
		max-height: 350px;
		background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
		margin-bottom: var(--space-2xl);
		border-bottom: 1px solid var(--color-accent-1);
	}

	.hero-overlay {
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		background: linear-gradient(180deg, transparent 0%, rgba(15, 26, 30, 0.6) 70%, var(--color-bg) 100%);
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding: var(--space-lg);
	}

	.hero-content {
		text-align: center;
		max-width: 800px;
		padding-bottom: var(--space-2xl);
	}

	.hero h1 {
		font-size: clamp(2rem, 3vw, 2.8rem);
		font-weight: 300;
		margin-bottom: var(--space-sm);
		color: var(--color-heading);
		font-family: var(--font-serif);
		letter-spacing: -0.02em;
	}

	.subtitle {
		font-size: clamp(0.95rem, 1.3vw, 1.1rem);
		color: var(--color-text-muted);
		font-weight: 300;
		font-style: italic;
	}

	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--space-lg) var(--space-3xl);
	}

	.era-section { margin-bottom: var(--space-3xl); }

	.era-section h2 {
		color: var(--color-heading);
		border-bottom: 1px solid var(--color-accent-1);
		padding-bottom: var(--space-sm);
		font-family: var(--font-serif);
		font-size: var(--font-size-2xl);
		margin-bottom: var(--space-xs);
	}

	.era-description {
		color: var(--color-text-muted);
		margin-bottom: var(--space-xl);
		font-size: var(--font-size-lg);
	}

	.chapters { display: grid; gap: var(--space-md); }

	.scene-card {
		border: 1px solid var(--color-border);
		border-left: 4px solid var(--color-accent-1);
		border-radius: 8px;
		padding: var(--space-lg);
		background: var(--color-bg-glass);
		transition: all var(--transition-normal);
		backdrop-filter: blur(10px);
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
	}

	.scene-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		border-left-color: var(--color-accent-2);
		border-color: var(--color-accent-2);
	}

	.scene-info { flex: 1; min-width: 0; }

	.card-top {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		margin-bottom: var(--space-xs);
	}

	.chapter-number {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent-1);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.status-badge {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--badge-color);
		border: 1px solid var(--badge-color);
		padding: 0.1rem 0.5rem;
		border-radius: 12px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.scene-card h3 {
		margin: 0;
		color: var(--color-heading);
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
	}

	.card-link {
		text-decoration: none;
		color: inherit;
		transition: color var(--transition-fast);
	}

	.card-link::after {
		content: '';
		display: block;
		position: absolute;
		top: 0; left: 0; right: 0; bottom: 0;
		z-index: 1;
	}

	.scene-card:hover .card-link { color: var(--color-accent-1); }

	.scene-meta {
		margin-left: var(--space-md);
		display: flex;
		align-items: center;
		gap: var(--space-md);
		white-space: nowrap;
		position: relative;
		z-index: 2;
	}

	.word-count, .reading-time {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.read-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-accent-1);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.7;
		transition: opacity var(--transition-fast);
	}

	.scene-card:hover .read-link { opacity: 1; }

	@media (max-width: 1024px) {
		.scene-card {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-sm);
		}
		.scene-meta { margin-left: 0; }
	}
</style>
